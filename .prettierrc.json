{
	"$schema": "https://json.schemastore.org/prettierrc",
	"singleQuote": true,
	"printWidth": 70,
	"trailingComma": "es5",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"semi": true,
	"requirePragma": false,
	"insertPragma": false,
	"useTabs": false,
	"tabWidth": 4,
	"arrowParens": "always",
	"proseWrap": "preserve",
	"singleAttributePerLine": true
}

